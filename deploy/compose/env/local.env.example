APP_IMAGE=tea-party-reservation-bot:local
BOT_APP_COMMAND=python -m tea_party_reservation_bot bot
WORKER_APP_COMMAND=python -m tea_party_reservation_bot worker
MIGRATION_COMMAND=alembic upgrade head
BOT_MIGRATE_ON_START=1
WORKER_MIGRATE_ON_START=0

TEA_PARTY_APP__ENV=local
TEA_PARTY_APP__LOG_LEVEL=DEBUG
TEA_PARTY_APP__TIMEZONE_NAME=Europe/Moscow
TEA_PARTY_APP__DEFAULT_CANCEL_DEADLINE_OFFSET_MINUTES=240

POSTGRES_DB=tea_party
POSTGRES_USER=tea_party
POSTGRES_PASSWORD=tea_party_local
POSTGRES_PORT=5432
TEA_PARTY_DATABASE__DSN=postgresql+psycopg://tea_party:tea_party_local@postgres:5432/tea_party

TEA_PARTY_TELEGRAM__BOT_TOKEN=replace-me
TEA_PARTY_TELEGRAM__GROUP_CHAT_ID=-1000000000000
TEA_PARTY_WORKER__OUTBOX_POLL_INTERVAL_SECONDS=5
TEA_PARTY_WORKER__OUTBOX_BATCH_SIZE=50
TEA_PARTY_WORKER__OUTBOX_RETRY_DELAY_SECONDS=30
